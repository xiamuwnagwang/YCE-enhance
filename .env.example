# yw-enhance 入口与透传配置
# 默认使用仓内脚本；如需特殊覆盖，可改成你自己的入口
YCE_YOUWEN_SCRIPT=./scripts/youwen.js
YCE_YOUWEN_API_URL=https://a.aigy.de
YCE_YOUWEN_TOKEN=
YCE_YOUWEN_ENHANCE_MODE=agent
YCE_YOUWEN_ENABLE_SEARCH=true
YCE_YOUWEN_MGREP_API_KEY=

# ace 检索入口与运行参数
YCE_ACE_SEARCH_SCRIPT=./scripts/ace-search.sh
YCE_ACE_BINARY=./vendor/darwin-arm64/ace-tool-rs
YCE_ACE_CONFIG=./vendor/ace-tool.json
YCE_ACE_MAX_LINES_PER_BLOB=800
YCE_ACE_UPLOAD_TIMEOUT=
YCE_ACE_UPLOAD_CONCURRENCY=
YCE_ACE_RETRIEVAL_TIMEOUT=60
YCE_ACE_NO_ADAPTIVE=false
YCE_ACE_NO_WEBBROWSER_ENHANCE_PROMPT=false

# YCE 编排参数（毫秒）
YCE_DEFAULT_MODE=auto
YCE_TIMEOUT_ENHANCE_MS=300000
YCE_TIMEOUT_SEARCH_MS=30000
