# yw-enhance 入口与透传配置
# 默认使用仓内脚本；如需特殊覆盖，可改成你自己的入口
YCE_YOUWEN_SCRIPT=./scripts/youwen.js
YCE_YOUWEN_API_URL=https://a.aigy.de
YCE_YOUWEN_TOKEN=
YCE_YOUWEN_ENHANCE_MODE=agent
YCE_YOUWEN_ENABLE_SEARCH=true
YCE_YOUWEN_MGREP_API_KEY=

# yce-engine 检索入口与运行参数（Windsurf Devstral 本地语义搜索）
# key 由脚本在运行时自动从本机 Windsurf state.vscdb 发现；
# 不依赖本地 Windsurf 时，可显式设置 YCE_API_KEY（兼容旧名 WINDSURF_API_KEY）
YCE_ENGINE_SCRIPT=./vendor/yce-engine/yce-engine.mjs
YCE_ENGINE_MAX_RESULTS=10
YCE_ENGINE_MAX_TURNS=3
# YCE_API_KEY=

# YCE 编排参数（毫秒）
YCE_DEFAULT_MODE=auto
YCE_TIMEOUT_ENHANCE_MS=300000
YCE_TIMEOUT_SEARCH_MS=30000
